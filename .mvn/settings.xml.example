<settings xmlns="http://maven.apache.org/SETTINGS/1.0.0"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:schemaLocation="http://maven.apache.org/SETTINGS/1.0.0 https://maven.apache.org/xsd/settings-1.0.0.xsd">

  <!--
    Copy this file to ~/.m2/settings.xml (or pass via -s) and replace placeholder values.
    Use this when Maven Central access is blocked by a proxy (HTTP 403/407).
  -->

  <mirrors>
    <mirror>
      <id>company-mirror</id>
      <name>Company Artifact Mirror</name>
      <url>https://YOUR-NEXUS-OR-ARTIFACTORY/repository/maven-public/</url>
      <mirrorOf>*</mirrorOf>
    </mirror>
  </mirrors>

  <!-- Optional proxy block if your network requires explicit proxy settings.
  <proxies>
    <proxy>
      <id>corp-proxy</id>
      <active>true</active>
      <protocol>http</protocol>
      <host>proxy.company.local</host>
      <port>8080</port>
      <nonProxyHosts>localhost|127.*|*.local</nonProxyHosts>
    </proxy>
  </proxies>
  -->

  <!-- Optional credentials for private mirror.
  <servers>
    <server>
      <id>company-mirror</id>
      <username>${env.MVN_REPO_USER}</username>
      <password>${env.MVN_REPO_PASS}</password>
    </server>
  </servers>
  -->
</settings>
