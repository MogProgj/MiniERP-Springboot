# Copy to .env for local development.
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5433/minierp
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=postgres

# Required JWT signing key (Base64 encoded, at least 32 raw bytes / 256 bits).
# Example generation:
#   openssl rand -base64 32
APP_JWT_SECRET=REPLACE_WITH_BASE64_256BIT_SECRET

# Optional token lifetime in milliseconds (default: 86400000)
APP_JWT_EXPIRATION_MS=86400000
